# ================== MuscleKing 环境变量配置 ==================
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ============================================================

# 应用配置
APP_NAME=MuscleKing
APP_VERSION=0.1.0
DEBUG=True

# API 配置
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# LLM 服务配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1

# CORS 配置
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# 视觉模型配置（可选）
# VISION_API_KEY=your-vision-api-key
# VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# VISION_MODEL=glm-4.6

# 图像生成模型配置（可选）
# IMAGE_GENERATION_API_KEY=your-image-api-key
# IMAGE_GENERATION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# IMAGE_GENERATION_MODEL=cogview-4

# Milvus 向量数据库配置
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_COLLECTION=fitness
# MILVUS_INDEX_TYPE=IVF_FLAT
# MILVUS_METRIC_TYPE=IP

# Embedding 服务配置
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_API_KEY=your-embedding-api-key
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_DIMENSION=1024

# Reranker 服务配置
# RERANK_ENABLED=true
# RERANK_PROVIDER=custom
# RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services
# RERANK_ENDPOINT=/rerank/text-rerank/text-rerank
# RERANK_MODEL=qwen3-rerank
# RERANK_API_KEY=your-rerank-api-key
# RERANK_MAX_CANDIDATES=20
# RERANK_TOP_N=6

# MySQL 数据库配置
# DATABASE_URL=mysql+pymysql://muscleking_user:musclepass@localhost:3306/muscleking_db

# Neo4j 配置
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=muscleking

# Redis 配置
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# LightRAG 配置
# LIGHTRAG_WORKING_DIR=./data/lightrag
# LIGHTRAG_RETRIEVAL_MODE=hybrid
# LIGHTRAG_TOP_K=10
# LIGHTRAG_ENABLE_NEO4J=True

# Agent 配置
# MAX_ITERATIONS=10
# AGENT_TIMEOUT=300

# 知识库配置
# KB_TOP_K=5
# KB_SIMILARITY_THRESHOLD=0.2
# KB_CHUNK_SIZE=512
# KB_CHUNK_OVERLAP=80
